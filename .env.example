NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Embed-friendly scheduler URL, e.g. Cal.com: https://cal.com/you/embed?theme=dark
NEXT_PUBLIC_BOOKING_URL=https://primecraft.mothership-ai.com/p/nexteleven
# Stripe Payment Link, Square checkout, or other HTTPS pay link (opens in new tab)
NEXT_PUBLIC_DEPOSIT_URL=

# Next.js (root .env.local) — prefer server vars so Vercel can update without rebuild surprises:
SANITY_PROJECT_ID=7sodez5h
SANITY_DATASET=production
SANITY_API_VERSION=2026-04-16

# Also supported (often inlined at build time):
NEXT_PUBLIC_SANITY_PROJECT_ID=7sodez5h
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-16

# Sanity Studio (sanity/.env) — required SANITY_STUDIO_* prefix for `npm run studio`
# https://www.sanity.io/docs/environment-variables
SANITY_STUDIO_PROJECT_ID=7sodez5h
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_API_VERSION=2026-04-16

SANITY_API_TOKEN=

RESEND_API_KEY=
# Must be a verified sender in Resend (often your domain).
RESEND_FROM_EMAIL=seanebones@gmail.com
# Where consultation form emails are delivered (can differ from public mailto in lib/site.ts).
CONTACT_INBOX_EMAIL=nextelevenstudios@gmail.com
